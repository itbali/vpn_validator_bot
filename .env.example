# Telegram Bot settings
BOT_TOKEN=your_bot_token_here
CHANNEL_ID=your_channel_id_here
ADMIN_IDS=123456789,987654321

# Outline VPN settings
OUTLINE_API_URL=https://your-server:port/api
OUTLINE_CERT_SHA256=your_cert_sha256_here

# Monitoring settings
CHECK_MEMBERSHIP_INTERVAL=3600
SERVER_CHECK_INTERVAL=300

# Thresholds
CPU_THRESHOLD=80.0
RAM_THRESHOLD=80.0
DISK_THRESHOLD=80.0
TRAFFIC_THRESHOLD=1000000000

# Database settings
DATABASE_URL=sqlite:///vpn_bot.db 